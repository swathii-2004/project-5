# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
# Local dev:  mongodb://localhost:27017/proximart
# Atlas:      mongodb+srv://<user>:<pass>@cluster.mongodb.net/proximart
MONGODB_URL=mongodb://localhost:27017/proximart

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
JWT_ALGORITHM=HS256

# ─────────────────────────────────────────────
# AES-256 encryption
# MUST be exactly 32 characters or the app will crash on startup.
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
# ─────────────────────────────────────────────
AES_SECRET_KEY=your_exactly_32_byte_secret_key!!

# ─────────────────────────────────────────────
# Cloudinary — Phase 3 product image uploads
# Get from: cloudinary.com → Dashboard → API Keys
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────
# SendGrid — Phase 2 approval / rejection emails
# Get from: sendgrid.com → Settings → API Keys → Create
# From email must be a verified sender in your SendGrid account.
# ─────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=no-reply@proximart.com

# ─────────────────────────────────────────────
# Frontend URLs — used for CORS allow-list
# ─────────────────────────────────────────────
FRONTEND_USER_URL=http://localhost:3000
FRONTEND_VENDOR_URL=http://localhost:3001
FRONTEND_ADMIN_URL=http://localhost:3002
